{
  "mcpServers": {
    "MCPToolkit": {
      "command": "python3",
      "args": [
        "C:\\MCPToolkit\\mcp-server\\server.py"
      ],
      "env": {}
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "dbt": {
      "command": "uvx",
      "args": [
        "dbt-mcp"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ]
    },
    "excel-mcp": {
      "command": "python3",
      "args": [
        "-m",
        "excel_mcp_server"
      ]
    },
    "duckdb": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_server_motherduck"
      ],
      "env": {
        "motherduck_token": "{MOTHERDUCK_TOKEN}"
      }
    },
    "qdrant": {
      "command": "uvx",
      "args": [
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "COLLECTION_NAME": "mcp-memory"
      }
    },
    "clickhouse": {
      "command": "uvx",
      "args": [
        "mcp-clickhouse"
      ],
      "env": {
        "CLICKHOUSE_HOST": "{CLICKHOUSE_HOST}",
        "CLICKHOUSE_USER": "default",
        "CLICKHOUSE_PASSWORD": "{CLICKHOUSE_PASSWORD}"
      }
    },
    "meilisearch": {
      "command": "python3",
      "args": [
        "-m",
        "meilisearch_mcp"
      ],
      "env": {
        "MEILI_HTTP_ADDR": "{MEILI_URL}",
        "MEILI_MASTER_KEY": "{MEILI_MASTER_KEY}"
      }
    },
    "snowflake": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_snowflake_server"
      ],
      "env": {
        "SNOWFLAKE_ACCOUNT": "{SNOWFLAKE_ACCOUNT}",
        "SNOWFLAKE_USER": "{SNOWFLAKE_USER}",
        "SNOWFLAKE_PASSWORD": "{SNOWFLAKE_PASSWORD}"
      }
    },
    "everything-search": {
      "command": "python3",
      "args": [
        "-m",
        "everything_mcp"
      ]
    },
    "obsidian": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_obsidian"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "{OBSIDIAN_TOKEN}",
        "OBSIDIAN_HOST": "http://localhost:27123"
      }
    },
    "mcp-pdf-reader": {
      "command": "python3",
      "args": [
        "-m",
        "mcp_pdf_reader"
      ]
    },
    "trello": {
      "command": "python3",
      "args": [
        "-m",
        "trello_mcp_server"
      ],
      "env": {
        "TRELLO_API_KEY": "{TRELLO_API_KEY}",
        "TRELLO_TOKEN": "{TRELLO_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "e2b": {
      "command": "npx",
      "args": [
        "-y",
        "@e2b/mcp-server"
      ],
      "env": {
        "E2B_API_KEY": "{E2B_API_KEY}"
      }
    },
    "desktop-commander": {
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "docker-mcp"
      ]
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-kubernetes"
      ]
    },
    "cloudflare": {
      "command": "npx",
      "args": [
        "-y",
        "@cloudflare/mcp-server-cloudflare"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "{CLOUDFLARE_API_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "{FIRECRAWL_API_KEY}"
      }
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "{EXA_API_KEY}"
      }
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@0.1.4"
      ],
      "env": {
        "TAVILY_API_KEY": "{TAVILY_API_KEY}"
      }
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server"
      ],
      "env": {
        "APIFY_TOKEN": "{APIFY_TOKEN}"
      }
    },
    "agentql": {
      "command": "npx",
      "args": [
        "-y",
        "agentql-mcp"
      ],
      "env": {
        "AGENTQL_API_KEY": "{AGENTQL_API_KEY}"
      }
    },
    "bright-data": {
      "command": "npx",
      "args": [
        "-y",
        "@brightdata/mcp"
      ],
      "env": {
        "BRIGHTDATA_API_TOKEN": "{BRIGHTDATA_API_TOKEN}"
      }
    },
    "a2asearch": {
      "command": "npx",
      "args": [
        "-y",
        "a2asearch-mcp"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ]
    },
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "@mongodb-js/mongodb-mcp-server"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "{MDB_CONNECTION_STRING}"
      }
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--supabase-access-token",
        "{SUPABASE_ACCESS_TOKEN}"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer {NOTION_TOKEN}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "slack-mcp-server"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "{SLACK_BOT_TOKEN}"
      }
    },
    "linear": {
      "command": "npx",
      "args": [
        "-y",
        "@tacticlaunch/mcp-linear"
      ],
      "env": {
        "LINEAR_API_TOKEN": "{LINEAR_API_TOKEN}"
      }
    },
    "todoist": {
      "command": "npx",
      "args": [
        "-y",
        "todoist-mcp-server"
      ],
      "env": {
        "TODOIST_API_TOKEN": "{TODOIST_API_TOKEN}"
      }
    },
    "google-drive": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gdrive"
      ]
    },
    "google-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-maps"
      ],
      "env": {
        "GOOGLE_MAPS_API_KEY": "{GOOGLE_MAPS_API_KEY}"
      }
    },
    "everything": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\elize"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "C:\\MCPToolkit"
      ]
    },
    "sqlite": {
      "command": "uvx",
      "args": [
        "mcp-server-sqlite",
        "--db-path",
        "C:\\Users\\elize\\data.db"
      ]
    }
  }
}